# ============================================================
# Classey — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# All NEXT_PUBLIC_ variables are exposed to the browser.
# All others are server-only (API routes, middleware).
# ============================================================

# ------------------------------------------------------------
# ACCESS CONTROL
# ------------------------------------------------------------

# The single password to access the app
# Set this in Vercel environment variables for production
APP_PASSWORD=your_secure_password_here

# Secret used to sign the auth cookie (min 32 random characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_COOKIE_SECRET=generate_a_random_32_char_secret_here

# ------------------------------------------------------------
# APPWRITE — CORE (get from Appwrite Console → Project Settings)
# ------------------------------------------------------------

# Your Appwrite Cloud endpoint (usually https://cloud.appwrite.io/v1)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID (found in Project Settings)
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Your Appwrite Database ID (created in Databases section)
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here

# Appwrite API Key — SERVER ONLY (never expose to browser)
# Create in Appwrite Console → Project Settings → API Keys
# Scopes needed: databases.read, databases.write, documents.read,
#   documents.write, storage.read, storage.write
APPWRITE_API_KEY=your_appwrite_api_key_here

# Appwrite Storage Bucket ID
NEXT_PUBLIC_APPWRITE_BUCKET_ID=your_bucket_id_here

# ------------------------------------------------------------
# APPWRITE — COLLECTION IDs
# Copy each collection ID from Appwrite Console after creating
# ------------------------------------------------------------

NEXT_PUBLIC_COL_SETTINGS=your_settings_collection_id
NEXT_PUBLIC_COL_GRADE_SCALES=your_grade_scales_collection_id
NEXT_PUBLIC_COL_SLOTS=your_slots_collection_id
NEXT_PUBLIC_COL_SEMESTERS=your_semesters_collection_id
NEXT_PUBLIC_COL_SUBJECTS=your_subjects_collection_id
NEXT_PUBLIC_COL_CLASS_SCHEDULES=your_class_schedules_collection_id
NEXT_PUBLIC_COL_CLASS_OCCURRENCES=your_class_occurrences_collection_id
NEXT_PUBLIC_COL_EXAMS=your_exams_collection_id
NEXT_PUBLIC_COL_TASKS=your_tasks_collection_id
NEXT_PUBLIC_COL_EVENTS=your_events_collection_id
NEXT_PUBLIC_COL_HOLIDAYS=your_holidays_collection_id
NEXT_PUBLIC_COL_RESOURCE_LINKS=your_resource_links_collection_id
NEXT_PUBLIC_COL_FILES=your_files_collection_id
NEXT_PUBLIC_COL_NOTIFICATIONS_LOG=your_notifications_log_collection_id
NEXT_PUBLIC_COL_AUDIT_LOG=your_audit_log_collection_id
NEXT_PUBLIC_COL_TAGS=your_tags_collection_id
NEXT_PUBLIC_COL_TAGGED_ITEMS=your_tagged_items_collection_id
NEXT_PUBLIC_COL_STUDY_SESSIONS=your_study_sessions_collection_id
NEXT_PUBLIC_COL_GOALS=your_goals_collection_id
NEXT_PUBLIC_COL_NOTES=your_notes_collection_id
NEXT_PUBLIC_COL_BACKUPS=your_backups_collection_id
NEXT_PUBLIC_COL_WIDGETS_CONFIG=your_widgets_config_collection_id
NEXT_PUBLIC_COL_AI_CONVERSATIONS=your_ai_conversations_collection_id

# ------------------------------------------------------------
# AI — GROQ (primary provider)
# Get from: console.groq.com → API Keys
# Free tier available — no credit card needed
# ------------------------------------------------------------

GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# AI — GOOGLE AI STUDIO (fallback provider)
# Get from: aistudio.google.com → API Keys
# Free tier available — no credit card needed
# ------------------------------------------------------------

GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ------------------------------------------------------------
# TELEGRAM BOT
# Get from: @BotFather on Telegram
# 1. Message @BotFather → /newbot
# 2. Follow instructions → get token
# 3. Message your bot → get chat_id from settings page
# ------------------------------------------------------------

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------

# Your app URL (replace with real Vercel URL after deploy)
NEXT_PUBLIC_APP_URL=https://classey.vercel.app

# Node environment (set automatically by Vercel)
NODE_ENV=development
